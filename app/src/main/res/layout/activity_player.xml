<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#D88C52"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="20dp">

        <ImageView
            android:id="@+id/btn_Back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_back"
            android:contentDescription="Back"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tv_AppTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Soundy"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <!-- Cover -->
    <ImageView
        android:id="@+id/imgCover"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_gravity="center"
        android:scaleType="centerCrop"
        android:src="@drawable/default_cover"
        android:background="@drawable/cover_circle"
        android:layout_marginVertical="12dp" />

    <!-- Time + SeekBar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="4dp">

        <TextView
            android:id="@+id/tv_CurrentTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:paddingEnd="8dp" />

        <SeekBar
            android:id="@+id/seek_Bar"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tv_Duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="04:23"
            android:paddingStart="8dp" />
    </LinearLayout>

    <!-- Song Title -->
    <TextView
        android:id="@+id/tv_Title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mở lối cho em"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center_horizontal"
        android:paddingTop="4dp" />

    <!-- Artist -->
    <TextView
        android:id="@+id/tv_Artist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Lương Huy Tuấn"
        android:textSize="14sp"
        android:gravity="center_horizontal"
        android:paddingBottom="8dp" />

    <!-- Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_marginTop="12dp"
        android:weightSum="4">

        <ImageView
            android:id="@+id/btn_Prev"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:src="@drawable/ic_prev"
            android:contentDescription="Prev"
            android:padding="8dp" />

        <ImageView
            android:id="@+id/btn_Stop"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:src="@drawable/ic_stop"
            android:contentDescription="Play/Pause"
            android:padding="8dp" />

        <ImageView
            android:id="@+id/btn_Next"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:src="@drawable/ic_next"
            android:contentDescription="Next"
            android:padding="8dp" />

        <ImageView
            android:id="@+id/btn_Loop"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:src="@drawable/ic_loop"
            android:contentDescription="Loop"
            android:padding="8dp" />
    </LinearLayout>
</LinearLayout>
